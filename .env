# ─── PostgreSQL ─────────────────────────────────────────────
# Full connection URL takes precedence over individual vars
DATABASE_URL=postgresql://datafeed:datafeed@localhost:5432/datafeed

# Individual vars (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=datafeed
PGUSER=datafeed
PGPASSWORD=datafeed

# ─── Exchange API keys ───────────────────────────────────────
JUPITER_API_KEY=your_jupiter_api_key_here
BIRDEYE_API_KEY=your_birdeye_api_key_here
CMC_API_KEY=your_coinmarketcap_api_key_here

# ─── Default exchange on startup ────────────────────────────
EXCHANGE=BINANCE
